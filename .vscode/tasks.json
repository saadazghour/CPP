{
  // ============================================
  // TASKS.JSON - Tells VSCode how to build/compile your C++ code
  // ============================================
  
  "tasks": [
    {
      // Type of task: cppbuild = C++ compilation
      "type": "cppbuild",

      // Display name shown in VSCode
      "label": "C/C++: g++ build active file",

      // Path to the compiler (g++ = GNU C++ compiler)
      "command": "/bin/g++",

      // Compiler flags/options:
      "args": [
        "-fdiagnostics-color=always",  // Show colored output
        "-g",                           // Include debugging info
        "${file}",                      // The current file (e.g., HelloWorld.cpp)
        "-o",                           // Output flag
        "${fileDirname}/${fileBasenameNoExtension}"  // Output filename (e.g., HelloWorld)
      ],

      // Options for running the command
      "options": {
        "cwd": "${fileDirname}"  // Run in the same folder as the file
      },

      // Pattern to match compiler errors/warnings
      "problemMatcher": [
        "$gcc"
      ],

      // Make this the default build task (runs with Ctrl+Shift+B)
      "group": {
        "kind": "build",
        "isDefault": true
      },

      // Description
      "detail": "Task generated by Debugger."
    }
  ],

  // Version of this config format
  "version": "2.0.0"
}
